# Source project path (defaults to ~/GitHub/newsletter-assistant)
# NEWSLETTER_ASSISTANT_DIR=~/GitHub/newsletter-assistant

# Dagster PostgreSQL connection (used by docker-compose)
DAGSTER_PG_HOST=postgres
DAGSTER_PG_PORT=5432
DAGSTER_PG_USERNAME=...
DAGSTER_PG_PASSWORD=...
DAGSTER_PG_DB=dagster

# OpenAI API key (used by wiki synthesis pipeline)
OPENAI_API_KEY=sk-...
